# Optional preset profile. Set this to skip the API URL and Tenant ID below.
# Currently supported profiles:
#   dinasi-stage    -> Dinasi Direct staging
# Leave empty for fully custom config.
CLOUDSHOPS_PROFILE=

# Backend gateway URL. No trailing slash. Required if no profile is set.
# When set, overrides any preset from CLOUDSHOPS_PROFILE.
CLOUDSHOPS_API_URL=

# JWT issued in your tenant admin -> Settings -> API Tokens.
# MUST have scope=analytics:read and tenant matching CLOUDSHOPS_TENANT_ID below.
# This token is shown only once when minted -- save it here, gitignored.
CLOUDSHOPS_API_TOKEN=

# Sent in the x-tenant header. Must match the tenant claim in the JWT.
# Required if no profile is set. When set, overrides any preset from CLOUDSHOPS_PROFILE.
CLOUDSHOPS_TENANT_ID=
